# Application Settings
FLASK_ENV=development
FLASK_APP=app.py
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=treedash
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# TimescaleDB Configuration
TIMESCALE_USER=postgres
TIMESCALE_PASSWORD=postgres
TIMESCALE_DB=timeseries
TIMESCALE_HOST=timescaledb
TIMESCALE_PORT=5433

# AWS Configuration
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-west-2
S3_BUCKET=your-bucket-name

# Elasticsearch Configuration
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# Monitoring Configuration
PROMETHEUS_METRICS_PORT=9090
GRAFANA_PORT=3000

# API Configuration
API_RATE_LIMIT=100
API_RATE_LIMIT_PERIOD=60

# Cache Configuration
CACHE_TYPE=redis
CACHE_REDIS_URL=redis://redis:6379/0
CACHE_DEFAULT_TIMEOUT=300

# ML Model Configuration
MODEL_CACHE_SIZE=1000
MODEL_BATCH_SIZE=32
MODEL_UPDATE_INTERVAL=3600

# Geospatial Configuration
DEFAULT_COORDINATE_SYSTEM=EPSG:4326
MAX_QUERY_AREA_SIZE=100
SPATIAL_INDEX_GRID_SIZE=0.1

# Feature Flags
ENABLE_REAL_TIME_UPDATES=true
ENABLE_ML_PREDICTIONS=true
ENABLE_ADVANCED_ANALYTICS=true
ENABLE_COLLABORATIVE_FEATURES=true

# Performance Optimization
MAX_CONNECTIONS=100
POOL_SIZE=20
POOL_TIMEOUT=30
CONNECTION_LIFETIME=600

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=/var/log/treedash/app.log

# Security Configuration
ALLOW_ORIGINS=http://localhost:3000,http://localhost:8050
SSL_CERT_PATH=/etc/ssl/certs/treedash.crt
SSL_KEY_PATH=/etc/ssl/private/treedash.key

# User Interface Configuration
UI_THEME=light
DEFAULT_MAP_CENTER_LAT=37.7749
DEFAULT_MAP_CENTER_LNG=-122.4194
DEFAULT_MAP_ZOOM=12

# Environmental Analysis Configuration
CLIMATE_DATA_SOURCE=noaa
CLIMATE_DATA_UPDATE_INTERVAL=86400
SPECIES_ANALYSIS_DEPTH=3
ECOSYSTEM_METRICS_ENABLED=true