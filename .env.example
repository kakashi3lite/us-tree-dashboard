# Flask Configuration
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=8050
SECRET_KEY=your-secret-key-here

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Database Configuration
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=us_tree_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache Configuration
ENABLE_CACHING=true
CACHE_TTL=300

# Rate Limiting Configuration
ENABLE_RATE_LIMITING=true
RATE_LIMIT_DEFAULT=100 per minute

# Monitoring Configuration
LOG_LEVEL=INFO
ENABLE_PROMETHEUS=true

# Security Configuration
SSL_CERT_PATH=
SSL_KEY_PATH=

# API Configuration
API_TIMEOUT=30

# Geospatial Configuration
DEFAULT_ZOOM_LEVEL=12
MAX_CLUSTER_RADIUS=0.1

# Performance Configuration
MAX_CONNECTIONS=100
POOL_SIZE=10
POOL_TIMEOUT=30

# Feature Flags
ENABLE_HISTORICAL_TRENDS=true
ENABLE_ENVIRONMENTAL_IMPACT=true
ENABLE_SPECIES_FILTERING=true